# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# External API Keys (Optional - improves rate limits and access)
# Groq API - LLM for summarization (FREE: 30 req/min) - Get key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Semantic Scholar API (FREE: 1 req/sec) - Get key: https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# OpenAlex API (FREE: 100 req/sec) - Get key: https://openalex.org/account
OPENALEX_API_KEY=your_openalex_api_key_here

# PubMed API (Optional - faster rate limit) - Get key: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=your_pubmed_api_key_here

# CORE API (Optional - faster rate limit) - Get key: https://core.ac.uk/services/api
CORE_API_KEY=your_core_api_key_here

# Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage Configuration
VECTORSTORE_PATH=./data/vectorstore